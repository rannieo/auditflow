# Copy to .env and edit. All values shown are safe defaults.

APP_ENV=development
DATABASE_URL=sqlite:///./auditflow.db
CORS_ORIGINS=http://localhost:5173

# AI provider — "mock" (default) or "ollama".
# If set to "ollama" but OLLAMA_API_KEY is empty, the app silently falls
# back to "mock" with a startup warning. The demo works with no key.
AI_PROVIDER=mock

# Ollama Cloud — https://docs.ollama.com/cloud
# Get a key at https://ollama.com/settings/keys
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_TIMEOUT_SECONDS=30

# Reserved for future providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
