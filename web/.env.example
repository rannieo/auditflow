# Copy to .env.local and edit. All values shown are safe defaults.

# In dev, leave as "/api" so requests go through the Vite proxy
# (configured in vite.config.ts). In production, set to a full origin,
# e.g. https://api.auditflow.example.com/api
VITE_API_BASE_URL=/api

VITE_APP_TITLE=AuditFlow AI Lite
